# Configuration de l'environnement
# Valeurs possibles: development, production, local, stage, test
ENV=example

# Ports d'application
# Port principal de l'application
APP_PORT=5188
# Port Redis pour l'environnement spécifique
REDIS_PORT=6379

# Configuration Redis
# Host Redis (peut être localhost ou le nom du service dans docker-compose)
REDIS_HOST=redis
# Port Redis standard
REDIS_PORT=6379
# Base de données Redis (0-15)
REDIS_DB=0
# Mot de passe Redis (à changer pour chaque environnement)
REDIS_PASSWORD=your_redis_password
# URL Redis complète avec authentification
REDIS_URL=redis://:{REDIS_PASSWORD}@localhost:6379/0

# Configuration de l'application
# Environnement Node.js (development, production, etc.)
NODE_ENV=development
# Port de l'application (doit correspondre à APP_PORT)
PORT=8088

# Configuration MongoDB
# URI de connexion MongoDB
MONGO_URI=mongodb://localhost:27017
# Nom de la base de données MongoDB
MONGO_DB_NAME=your_db_name

# Configuration de sécurité
# Clé secrète pour le chiffrement général
SECRET_KEY=your_secret_key_here
# Clé secrète pour reCAPTCHA
RECAPTCHA_SECRET=your_recaptcha_secret_here
# Algorithme JWT (HS256 recommandé)
JWT_ALGORITHM=HS256
# Clé secrète pour JWT
JWT_SECRET_KEY=replace_me_with_a_local_secret
# Durée de validité du token en minutes
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Configuration du chiffrement
# Clé de chiffrement pour les données sensibles
ENCRYPTION_KEY=replace_me_with_a_fernet_key
# Clé secrète de chiffrement
ENCRYPTION_SECRET_KEY=replace_me_with_a_local_secret
# Clé dédiée pour le chiffrement des champs de base de données
ENCRYPTION_DB_SECRET_KEY=replace_me_with_a_local_secret

# URLs des services
# URL de l'API
API_URL=http://localhost:8088
# URL du frontend Angular
FRONTEND_URL=http://localhost:4000
# URL du backend
BACKEND_URL=http://localhost:8088
# URL de base pour l'application Angular
FRONT_END_ANGULAR_BASE_URL=http://localhost:8016
# URL du système de fichiers senat_digit
SENAT_DIGIT_APPS_FILE_SYSTEM_URL=http://127.0.0.1:9874/api/v1
# Token d'authentification pour le système de fichiers
SENAT_DIGIT_APPS_FILE_BEARER_TOKEN=replace_me_with_a_file_api_token
# Répertoire pour les logos des organisations
SENAT_DIGIT_APPS_FILE_ORGANIZATION_LOGO_BASE_DIR=organization_logo
# Répertoire pour les signatures des utilisateurs
SENAT_DIGIT_APPS_FILE_ORGANIZATION_USER_SIGNATURE_BASE_DIR=users_signatures
# URL de base pour la chaîne de dépenses
MAIN_APP_BASE_URL=http://127.0.0.1:8088/api/v1

# Configuration SMTP
# Serveur SMTP
SMTP_HOST=smtp.example.com
# Port SMTP (587 pour TLS)
SMTP_PORT=587
# Utiliser TLS (True/False)
SMTP_SECURE=False
# Nom d'utilisateur SMTP
SMTP_AUTH_USER=your_smtp_user
# Mot de passe SMTP
SMTP_AUTH_PASS=your_smtp_password
# Nom d'expéditeur pour les emails
SMTP_FROM_NAME=Your App Support
# Email d'expéditeur
SMTP_FROM_EMAIL=noreply@example.com

# Configuration SMS
# ID de l'expéditeur SMS
SMS_SENDER_ID=Your App
# URL de l'API SMS
SMS_POST_URL=https://sms-api.example.com/send
# Token d'authentification SMS
SMS_TOKEN=your_sms_token_here
# Clé API SMS
SMS_API_KEY=your_sms_api_key
# Secret API SMS
SMS_API_SECRET=your_sms_api_secret
# Numéro d'envoi SMS
SMS_FROM_NUMBER=your_sms_number

# Configuration des administrateurs
# Nom d'utilisateur administrateur
ADMIN_USERNAME=admin
# Mot de passe administrateur
ADMIN_PASSWORD=change_me_locally
# Email administrateur
ADMIN_EMAIL=admin@example.com
# Numéro de téléphone administrateur
ADMIN_PHONE_NUMBER=your_admin_phone
# Nom d'utilisateur basique
BASIC_USERNAME=user
# Mot de passe utilisateur basique
BASIC_PASSWORD=change_me_locally
# Email utilisateur basique
BASIC_USER_EMAIL=user@example.com

TOTP_ISSUER=ISSUER
