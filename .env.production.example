# ─────────────────────────────────────────────────────────────────────
# Senat-Digit API — production environment template
# ─────────────────────────────────────────────────────────────────────
# Copy to `.env.production` and fill the `<...>` slots.
# Run `bash bash/utils/generate_production_secrets.sh` to fill the
# crypto keys (JWT, Fernet, etc) with cryptographically-strong values.
#
# `.env.production` MUST stay out of git (already covered by
# `senat_digit_api/.gitignore`). Verify before any commit:
#   git check-ignore -v senat_digit_api/.env.production
#
# docker-compose `prod` profile reads this file via `--env-file`:
#   docker compose --env-file .env.production --profile prod up -d
# ─────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────
APP_PORT=9396
PORT=9396
ENV=production
NODE_ENV=production

# ── Mongo ───────────────────────────────────────────────────────────
# Use Atlas (managed) or self-hosted with auth + TLS.
# Format: mongodb+srv://<user>:<pwd>@<cluster>/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<user>:<pwd>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=senat_digit_prod

# ── Redis ───────────────────────────────────────────────────────────
# ElastiCache or self-hosted with TLS + AUTH.
REDIS_HOST=<redis-host.example.com>
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=<rotate-via-secret-manager>
REDIS_URL=redis://:<password>@<redis-host>:6379/0

# ── Crypto / auth ───────────────────────────────────────────────────
# All four below are SECRETS. Fill via `bash bash/utils/generate_production_secrets.sh`
# OR generate manually:
#   python -c "import secrets; print(secrets.token_hex(32))"          # for *_SECRET_KEY
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # for ENCRYPTION_KEY
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=replace_me_with_a_local_secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

SECRET_KEY=<64-hex-chars>
RECAPTCHA_SECRET=<64-hex-chars>
ENCRYPTION_KEY=replace_me_with_a_fernet_key
ENCRYPTION_SECRET_KEY=replace_me_with_a_local_secret
ENCRYPTION_DB_SECRET_KEY=replace_me_with_a_local_secret

TOTP_ISSUER=Sénat-Digit

# ── URLs / CORS ─────────────────────────────────────────────────────
API_URL=https://api.senat-digit.cd
BACKEND_URL=https://api.senat-digit.cd
FRONTEND_URL=https://app.senat-digit.cd
FRONT_END_ANGULAR_BASE_URL=https://admin.senat-digit.cd
ALLOWED_ORIGINS=https://app.senat-digit.cd,https://admin.senat-digit.cd

# ── File-storage service (`senat_digit_fs_api`) ─────────────────────
SENAT_DIGIT_APPS_FILE_SYSTEM_URL=https://fs.senat-digit.cd/api/v1
SENAT_DIGIT_APPS_FILE_BEARER_TOKEN=replace_me_with_a_file_api_token
SENAT_DIGIT_APPS_FILE_ORGANIZATION_LOGO_BASE_DIR=organization_logo
SENAT_DIGIT_APPS_FILE_ORGANIZATION_USER_SIGNATURE_BASE_DIR=users_signatures

# ── Default admin (initial bootstrap only) ──────────────────────────
# These are seeded on first run. Rotate via the admin UI once an
# operator account exists. Keep them strong even though they're
# short-lived — they create the founder account.
ADMIN_USERNAME=admindpsenat
ADMIN_PASSWORD=change_me_locally
ADMIN_EMAIL=admin@senat-rdc.cd
ADMIN_PHONE_NUMBER=243831000000

# Basic-auth fallback for OPS dashboards (Grafana, etc) the API
# proxies — only used if a tenant enables basic auth on a particular
# admin URL. Optional; keep blank if not used.
BASIC_USERNAME=
BASIC_PASSWORD=change_me_locally
BASIC_USER_EMAIL=

# ── SMTP (transactional email — OTPs, password resets) ─────────────
SMTP_HOST=<smtp.example.com>
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_AUTH_USER=<smtp-user>
SMTP_AUTH_PASS=<smtp-pass>
SMTP_FROM_EMAIL=no-reply@senat-rdc.cd
SMTP_FROM_NAME=Sénat-Digit

# ── SMS (OTP fallback / notifications) ─────────────────────────────
SMS_POST_URL=https://api.lisoloo.cd/v1/messages
SMS_API_KEY=<provider-key>
SMS_API_SECRET=<provider-secret>
SMS_TOKEN=<provider-token>
SMS_SENDER_ID=SENAT
SMS_FROM_NUMBER=+243831000000
LISOLOO_API_URL=https://api.lisoloo.cd/v1
LISOLOO_API_KEY=<provider-key>

# ── Firebase (FCM push) ────────────────────────────────────────────
# The service-account JSON file lives at
#   `senat_digit_api/firebase-service-account.json`
# (NOT committed; mounted read-only into the docker image).
# `app/modules/core/services/firebase/firebase_service.py` finds it
# automatically. If you'd rather keep the JSON elsewhere, set:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/local-service-account.json
