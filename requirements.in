#requirements.in

# FastAPI: A modern, fast (high-performance) web framework for building APIs with Python.
fastapi

# Motor: An async Python driver for MongoDB, designed to work with asyncio.
motor

# PyMongo: The official synchronous MongoDB driver for Python.
pymongo

# Redis: A Python client for Redis, an in-memory data structure store.
redis

# Pydantic: A data validation and settings management library using Python type hints.
pydantic

# Pydantic-Settings: An extension of Pydantic for managing application settings.
pydantic-settings

# Pydantic[email]: Adds email validation capabilities to Pydantic.
pydantic[email]

# Passlib[argon2]: A password hashing library supporting Argon2 for secure password storage.
passlib[argon2]

# SlowAPI: A rate-limiting library for FastAPI.
# slowapi

# Python-JOSE: A library for encoding and decoding JSON Web Tokens (JWT).
python-jose

# Python-Docx: A library for creating and updating Microsoft Word (.docx) files.
python-docx

# PyPDF2: A library for working with PDF files, including reading and writing.
PyPDF2

# Requests: A popular HTTP client library for making synchronous HTTP requests.
requests

# HTTPX: A fully async HTTP client for Python, similar to requests but async.
httpx

# Beanie: An async ODM (Object Document Mapper) for MongoDB, built on Motor and Pydantic.
beanie

# Googletrans: A Python wrapper for Google Translate API, used for language translation.
googletrans

# Uvicorn: A lightning-fast ASGI server for serving FastAPI applications.
uvicorn

# Gunicorn: A Python WSGI HTTP Server for UNIX, used for production deployment.
gunicorn

# Nest-Asyncio: Allows nested use of asyncio event loops.
nest_asyncio

# Python-Multipart: A library for handling multipart form data, required for file uploads.
python-multipart

# Cryptography: A library for cryptographic recipes and secure communication.
cryptography

# Python-Dotenv: A library for loading environment variables from .env files.
python-dotenv

# Pillow: The Python Imaging Library for image processing tasks.
pillow

pandas

openpyxl

pydantic-extra-types

phonenumbers

pyotp

Jinja2

weasyprint

num2words

uvicorn
